{
  "apphosting": {
    "backendId": "jamlumauig-dev",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ]
  },
  "hosting": {
    "site": "jamlumauig-dev",
    "public": ".",
    "cleanUrls": true,
    "rewrites": [
      { "source": "/about", "destination": "/about.html" },
      { "source": "/projects", "destination": "/projects.html" },
      { "source": "/experience", "destination": "/experience.html" },
      { "source": "/", "destination": "/index.html" }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
